#!/usr/bin/env bash
# Pre-commit hook for 143: enforce multi-tenancy guardrails + gofmt before code
# leaves the developer's machine. Installed via `make hooks-install`.
#
# To skip (rare): `git commit --no-verify`.
# To uninstall:   `make hooks-uninstall`.
set -euo pipefail

# Only check files staged for this commit.
staged=$(git diff --cached --name-only --diff-filter=ACMR)

# Exit fast when no staged files (e.g. empty commit).
if [[ -z "$staged" ]]; then
  exit 0
fi

has_go=0
has_migration=0
has_store=0

while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  case "$f" in
    *.go)                    has_go=1 ;;
  esac
  case "$f" in
    migrations/*.up.sql)     has_migration=1 ;;
    internal/db/*.go)        has_store=1 ;;
  esac
done <<< "$staged"

fail=0
run_check() {
  local label="$1"
  shift
  printf '  [pre-commit] %s ... ' "$label"
  if out=$("$@" 2>&1); then
    echo "OK"
  else
    echo "FAIL"
    echo "$out" | sed 's/^/    /'
    fail=1
  fi
}

if [[ $has_migration -eq 1 ]]; then
  run_check "lint-schema" go run ./cmd/lint-schema
fi

if [[ $has_store -eq 1 ]]; then
  run_check "lint-stores" go run ./cmd/lint-stores
fi

if [[ $has_go -eq 1 ]]; then
  # gofmt: format-check staged Go files only, quickly.
  staged_go=$(echo "$staged" | grep '\.go$' || true)
  if [[ -n "$staged_go" ]]; then
    printf '  [pre-commit] gofmt ... '
    # shellcheck disable=SC2086
    unformatted=$(gofmt -l $staged_go)
    if [[ -z "$unformatted" ]]; then
      echo "OK"
    else
      echo "FAIL"
      echo "    The following files are not gofmt-clean:" >&2
      echo "$unformatted" | sed 's/^/      /' >&2
      echo "    Fix with: gofmt -w ${unformatted//$'\n'/ }" >&2
      fail=1
    fi
  fi
fi

if [[ $fail -ne 0 ]]; then
  echo ""
  echo "Pre-commit checks failed. Fix the issues above and re-stage." >&2
  echo "To bypass (rare, e.g. WIP): git commit --no-verify" >&2
  exit 1
fi

exit 0
