# 143 Environment Configuration
#
# Quick start:
#   cp .env.example .env        # create your local config
#   $EDITOR .env                # fill in your API keys
#
# For personal overrides without touching .env, create .env.local —
# it takes precedence over .env and is gitignored.
#
# Loading order (highest priority wins):
#   1. Real env vars (CI, Docker, secret manager)
#   2. .env.local (personal overrides, gitignored)
#   3. .env (shared defaults, gitignored)
#
# At startup, the server logs which features are configured so you can
# see immediately what's working without reading this file.

# Database
DATABASE_URL=postgres://onefortythree:dev@localhost:5432/onefortythree?sslmode=disable

# Server
PORT=8080
LOG_LEVEL=debug
MODE=all
BASE_URL=http://localhost:8080
# FRONTEND_URL and CORS_ALLOWED_ORIGINS default to BASE_URL if not set.
# Override only if the frontend is on a different origin:
# FRONTEND_URL=http://localhost:3000
# CORS_ALLOWED_ORIGINS=http://localhost:3000
SESSION_SECRET=change-me-to-random-secret

# GitHub OAuth (create at https://github.com/settings/applications/new)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Override the OAuth callback URL sent to GitHub. Defaults to BASE_URL + /api/v1/auth/github/callback.
# Set this when BASE_URL doesn't match the callback URL registered in your GitHub OAuth App
# (e.g. behind a reverse proxy, using a tunnel, or running on a non-standard port).
# GITHUB_OAUTH_REDIRECT_URI=https://example.com/api/v1/auth/github/callback

# Linear OAuth (create in Linear OAuth applications settings)
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=

# Sentry OAuth (create at Sentry → Settings → Developer Settings → New Public Integration)
SENTRY_OAUTH_CLIENT_ID=
SENTRY_OAUTH_CLIENT_SECRET=

# Slack OAuth
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub App (create at https://github.com/settings/apps/new)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_DSN=

# ── AWS / S3-Compatible Storage ──────────────────────────────────────
# Used by WAL-G (backups), file uploads, and snapshot storage.
# Works with any S3-compatible provider (AWS, Hetzner Object Storage, MinIO).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT=https://your-s3-endpoint.com   # omit for real AWS S3
# AWS_REGION=us-east-1

# ── Production Deployment ───────────────────────────────────────────
# DB_PASSWORD=                        # Postgres password
# DB_HOST=10.0.0.3                    # Private IP of the database node
# DB_BIND_IP=10.0.0.3                 # DB primary/private bind IP for in-region fallback
# GHCR_TOKEN=                         # GitHub Container Registry token (ghp_xxxx)
# NODE_ID=app-1                       # Unique identifier for this node in the fleet
# TS_AUTH_KEY_APP=                    # Optional: app-node Tailscale auth key
# TS_AUTH_KEY_DB=                     # Optional: db/subnet-router Tailscale auth key
# TS_AUTH_KEY_WORKER=                 # Optional: worker Tailscale auth key
# TS_TAG_APP=tag:prod-app             # Optional: app-node Tailscale ACL tag
# TS_TAG_DB=tag:prod-db               # Optional: db/subnet-router Tailscale ACL tag
# TS_TAG_WORKER=tag:prod-worker       # Optional: worker Tailscale ACL tag
# TS_DB_ADVERTISE_ROUTES=10.0.0.3/32  # Optional: advertise DB private IP over Tailscale
# TS_WORKER_HOSTS=worker-usw-1:1.2.3.4 # Optional: workers that should join Tailscale

# ── Backups (production only) ────────────────────────────────────────
# Local pg_dump backup directory and retention
# BACKUP_DIR=/backups/postgres
# BACKUP_RETENTION_DAYS=30
# POSTGRES_CONTAINER=143-postgres-1
# WALG_S3_PREFIX=s3://143-backups/wal-g

# ── Email (SMTP) ─────────────────────────────────────────────────────
# Optional — when not configured, invitation emails are logged to console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# ── LLM ──────────────────────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-6
# OPENAI_API_TYPE=                  # "chat_completions" or "responses"
# OPENROUTER_APP_NAME=143-dev
