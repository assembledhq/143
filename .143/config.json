{
  "dependencies": {
    "golangci-lint": "2.10.1"
  },
  "preview": {
    "name": "manado",
    "primary": "frontend",
    "install": {
      "command": ["sh", ".143/preview-install-frontend.sh"],
      "lockfiles": ["frontend/package-lock.json"],
      "verify_paths": ["frontend/node_modules/.bin/next"],
      "timeout_seconds": 600,
      "cache": {
        "paths": ["frontend/.next/cache"]
      }
    },
    "services": {
      "frontend": {
        "command": ["sh", ".143/preview-frontend.sh"],
        "port": 3000,
        "env": {
          "API_PROXY_TARGET": "http://localhost:8080",
          "NEXT_PUBLIC_API_URL": "",
          "NODE_OPTIONS": "--max-old-space-size=1280"
        },
        "ready": {
          "http_path": "/",
          "timeout_seconds": 240
        }
      },
      "server": {
        "command": ["sh", ".143/preview-start.sh"],
        "port": 8080,
        "env": {
          "MODE": "api",
          "LOG_LEVEL": "info",
          "DEMO_MODE": "true",
          "PREVIEW_GATEWAY_PORT": "0"
        },
        "ready": {
          "http_path": "/readyz",
          "timeout_seconds": 240
        }
      }
    },
    "infrastructure": {
      "db": {
        "template": "postgres-17",
        "inject_env": {
          "DATABASE_URL": "postgres://{{username}}:{{password}}@{{host}}:{{port}}/{{database}}?sslmode=disable"
        },
        "inject_into": ["server"]
      }
    },
    "credentials": {
      "mode": "none"
    },
    "network": {
      "mode": "managed"
    }
  }
}
