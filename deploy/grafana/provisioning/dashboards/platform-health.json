    {
      "type": "table",
      "id": 43,
      "title": "Sandbox auth and credential wiring failures",
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 65 },
