      "targets": [{ "refId": "A", "queryType": "statsRange", "expr": "service:api AND (_msg:\"request\" OR _msg:\"request failed\") | stats by (status_class) count() as requests", "step": "$__interval" }]
    },
    {
      "type": "timeseries",
