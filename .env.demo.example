# Public direct-entry demo. This file is copied to /opt/143-demo/.env.demo
# by make provision-demo and filled with generated local secrets.

IMAGE_REGISTRY=ghcr.io/assembledhq
IMAGE_TAG=latest

DOMAIN=demo.143.dev
BASE_URL=https://demo.143.dev
FRONTEND_URL=https://demo.143.dev
CORS_ALLOWED_ORIGINS=https://demo.143.dev

# Generated during provisioning on the demo host. Do not commit real values.
DB_PASSWORD=replace-with-generated-password
SESSION_SECRET=replace-with-generated-session-secret
CSRF_SIGNING_KEY=replace-with-generated-csrf-key
ENCRYPTION_MASTER_KEY=replace-with-generated-encryption-key
GITHUB_WEBHOOK_SECRET=replace-with-generated-webhook-secret

DEMO_MODE=true
DEMO_READ_ONLY=true
DEMO_ENTRY_EMAIL=preview-viewer@143.dev

DATABASE_MAX_CONNS=10
DATABASE_MAX_CONN_IDLE_TIME=5m
