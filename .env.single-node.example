# 143 single-node production compose configuration.
#
# Usage:
#   cp .env.single-node.example .env.single-node
#   sudo deploy/scripts/prepare-single-node.sh
#   # copy the printed DOCKER_GID value below
#   docker compose --env-file .env.single-node -f docker-compose.single-node.yml up -d

# Runtime images. Use a release SHA/tag for repeatable deploys. If GHCR images
# are private in your environment, run `docker login ghcr.io` first or point
# IMAGE_REGISTRY at your mirror/local registry.
IMAGE_REGISTRY=ghcr.io/assembledhq
IMAGE_TAG=latest

# Public origins.
DOMAIN=example.com
BASE_URL=https://example.com
FRONTEND_URL=https://example.com
CORS_ALLOWED_ORIGINS=https://example.com
PREVIEW_ORIGIN_TEMPLATE=https://{id}.preview.example.com

# Caddy uses the bundled Cloudflare DNS provider for wildcard preview TLS.
CLOUDFLARE_API_TOKEN=

# Required production secrets. Generate each with at least 32 random chars.
DB_PASSWORD=
SESSION_SECRET=
ENCRYPTION_MASTER_KEY=
CSRF_SIGNING_KEY=

# Filled in by: sudo deploy/scripts/prepare-single-node.sh
DOCKER_GID=

# GitHub OAuth app.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub App. Store the PEM on one line with literal \n line breaks.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# Optional GitHub App user-auth flow for user-authored PRs.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# LLM configuration. Set at least one provider key.
LLM_MODEL=claude-sonnet-4-6
PLATFORM_LLM_MODEL=gpt-5.4-nano
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Worker capacity for a small single node. Raise after watching host metrics.
WORKER_PROCESS_COUNT=1
WORKER_MAX_ACTIVE_SANDBOXES=1
SANDBOX_CPU_LIMIT=2
SANDBOX_MEMORY_LIMIT_MB=3072
SANDBOX_DISK_LIMIT_GB=10

# Production isolation defaults. Set SANDBOX_REQUIRE_GVISOR=false only for a
# trusted, non-production evaluation box.
SANDBOX_RUNTIME=runsc
SANDBOX_REQUIRE_GVISOR=true
SANDBOX_REQUIRE_DISK_QUOTA=false

# Stable local storage shared with durable session-executor containers.
# Keep the defaults on Linux. Override these only for local smoke tests or
# custom host layouts where /var/lib or /var/run are not bind-mountable.
SINGLE_NODE_DATA_DIR=/var/lib/143
# HOST_143_DIR=/etc/143
# SANDBOX_RESOLV_CONF=/etc/143/sandbox-resolv.conf
# SANDBOX_AUTH_SOCKET_DIR=/var/run/143/sandbox-auth
# PREVIEW_DEPENDENCY_CACHE_LOCAL_DIR=/var/cache/143/preview-dependency-cache
SESSION_EXECUTOR_DOCKER_NETWORK=143-single-node
# SESSION_EXECUTOR_EXTRA_BINDS defaults to SINGLE_NODE_DATA_DIR:SINGLE_NODE_DATA_DIR
# in docker-compose.single-node.yml. Set it only if session executors need
# additional host paths, and keep SINGLE_NODE_DATA_DIR included when overriding.
# SESSION_EXECUTOR_EXTRA_BINDS=/var/lib/143:/var/lib/143

# Optional integrations.
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
LINEAR_WEBHOOK_SIGNING_SECRET=
LINEAR_AGENT_ENABLED=false
SENTRY_OAUTH_CLIENT_ID=
SENTRY_OAUTH_CLIENT_SECRET=
SENTRY_DSN=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
PAGERDUTY_OAUTH_CLIENT_ID=
PAGERDUTY_OAUTH_CLIENT_SECRET=

# Optional SMTP. If unset, invitation links are logged instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
