# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env files (never commit secrets — plaintext or encrypted)
.env
.env.local
.env.pre-ngrok
.env.staging
.env.production
.env.single-node
.env.demo
.env.*.local
# SOPS-encrypted bundles and .sops.yaml live in the private secrets repo
# (../143-infra), never here: ciphertext published in a public repo can't
# be unpublished if a decryption key ever leaks. (The transient staging
# copies sync-static-egress-secrets.sh creates next to the bundle land in
# the private checkout, which carries its own ignore for them.)
.env*.enc
.env*.enc.*
.sops.yaml
# CI checkout location of the private secrets repo (see deploy.yml)
.infra/
# Production deploy SSH access control lives in the private 143-infra repo.
/deploy/authorized_keys/

# air live reload
tmp/
.tmp/

# Build output
bin/
sandbox/.build-stamp

# Runtime data (sandbox snapshots, etc.)
.data/
server
!cmd/server/
!cmd/server/session_executor_main.go
coverage.html

# Root-level `go build` artifacts, one per cmd/ package (rooted so the
# cmd/* source directories stay tracked)
/preview
/tools
/migrate
/worker-deployctl
/mcp
/backfill-usage
/deploy-guardrail
/lint-schema
/lint-stores

# Go module/build caches (if created locally)
.gomodcache/
.gopath/
.cache/

# Node modules
node_modules/

# Editor/IDE
# .idea/
# .vscode/

# Claude local settings
.claude/settings.local.json
.claude/worktrees/

# 143-tools CLI cross-compile output (make build-cli)
dist/
