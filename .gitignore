# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env files (never commit plaintext secrets)
.env
.env.local
.env.pre-ngrok
.env.staging
.env.production
.env.*.local
# .env*.enc files are SOPS-encrypted — safe to commit (intentionally NOT listed here)
# ...but the transient staging copies they're edited through (.env*.enc.XXXXXX
# from sync-static-egress-secrets.sh) must never be committed.
.env*.enc.*

# air live reload
tmp/

# Build output
bin/
sandbox/.build-stamp

# Runtime data (sandbox snapshots, etc.)
.data/
server
!cmd/server/
!cmd/server/session_executor_main.go
coverage.html

# Go module/build caches (if created locally)
.gomodcache/
.gopath/

# Node modules
node_modules/

# Editor/IDE
# .idea/
# .vscode/

# Claude local settings
.claude/settings.local.json
.claude/worktrees/
